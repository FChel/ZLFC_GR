<mvc:View
	controllerName="au.gov.defence.roman.zfss.gr.controller.App"
	displayBlock="true"
	height="100%"	
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc">
	<Shell id="shell"
		homeIcon="{
          icon: 'images/logo.png',
          favicon: 'images/logo.png',
          precomposed: false
        }">	
		<App id="app"
			busy="{appView>/busy}"
			busyIndicatorDelay="{appView>/delay}">
		</App>
	</Shell>
</mvc:View>